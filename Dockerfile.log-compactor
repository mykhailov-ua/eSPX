# Log compactor: downsampled warm-tier archives from rotated tracker audit segments.
FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -tags timetzdata -ldflags="-s -w" -o /bin/log-compactor ./cmd/log-compactor

FROM gcr.io/distroless/static-debian12
COPY --from=builder /bin/log-compactor /log-compactor
USER nonroot:nonroot
ENTRYPOINT ["/log-compactor"]
