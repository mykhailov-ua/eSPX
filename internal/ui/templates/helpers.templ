package templates

templ CopyableID(value string, label string) {
	<span class="copyable-id">
		<span class="copyable-id__label">{ label }</span>
		<button type="button" class="copyable-id__value metric-inline" data-copy={ value } title={ "Copy " + label }>
			{ value }
		</button>
	</span>
}

templ CopyableText(value string, label string) {
	<button type="button" class="copyable-text metric-inline" data-copy={ value } title={ "Copy " + label }>
		{ value }
	</button>
}
