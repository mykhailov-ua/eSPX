# Secrets & environment
.env.secrets
*.env

# Build output & vendored deps
bin/
vendor/

# Generated code (make gen / make proto — repo keeps sources only)
/api/gen/
/gen/

# sqlc (queries/*.sql + migrations/)
internal/*/db/*.sql.go
internal/*/db/db.go
internal/*/db/models.go
internal/*/db/querier.go
internal/ingestion/sqlc/

# protobuf / vtproto (api/*.proto → internal/*/pb/)
internal/*/pb/*.pb.go
internal/*/pb/*_grpc.pb.go
internal/*/pb/*_vtproto.pb.go

# bpf2go (deploy/edge-xdp/bpf/*.c → internal/edge/bpf/)
internal/edge/bpf/edge_bpf*.go
internal/edge/bpf/*.o
deploy/edge/xdp/bpf/*.o
deploy/edge/xdp/bpf/*.disasm.txt

# Dev TLS (generate via deploy/nginx/certs/generate-dev-certs.sh)
deploy/nginx/certs/*.key
deploy/nginx/certs/*.crt

# IDE
.idea/
.vscode/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Local runtime state
campaigns_replica.json
campaigns_replica.json.tmp
var/

# Go test & profiling artifacts
.cache/
coverage.out
*.coverprofile
*.prof
*.test

# Python (scripts/fraud-scoring training)
__pycache__/
*.py[cod]
.venv/
venv/

# Perf gate & benchmark reports (local / CI scratch)
.ci-baselines/
pr_bench.txt
baseline_bench.txt
gate_report.txt
escape_report.txt
*_bench.txt

# OS junk
.DS_Store
Thumbs.db

# GeoIP (download MaxMind separately; keep deploy/geoip/.gitkeep)
deploy/geoip/*.mmdb

# Terraform state & plugins
deploy/terraform/**/.terraform/
deploy/terraform/**/terraform.tfstate*

# Rendered deploy configs (scripts/k8s/render_prometheus_k3s.sh, etc.)
deploy/monitoring/*.rendered.yaml
