# RTB — copy into .env when enabling live soak (or use deploy/rtb/docker-compose.override.yml).

# off | shadow | live
RTB_MODE=off

# redis | rtb (live soak uses rtb)
RTB_BUDGET_AUTHORITY=redis

RTB_CLEARING_MODE=second
RTB_TARGETING_INDEX=false
RTB_SNAPSHOT_PATH=/var/lib/espx/rtb_snapshot.bin
RTB_RECONCILE_INTERVAL_MS=30000
RTB_BUDGET_DIVERGENCE_THRESHOLD_MICRO=1000
RTB_RECONCILE_SAMPLE_SIZE=32

# Live soak example:
# RTB_MODE=live
# RTB_BUDGET_AUTHORITY=rtb
