        {
          "expr": "histogram_quantile(0.95, sum(rate(ad_http_request_duration_seconds_bucket{job=\"tracker\"}[5m])) by (le)) * 1000",
          "legendFormat": "tracker p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ad_http_request_duration_seconds_bucket{job=\"tracker\"}[5m])) by (le)) * 1000",
          "legendFormat": "tracker p99",
          "refId": "B"
