<!-- users.xml: default ClickHouse credentials for docker compose dev and staging. -->
<!-- Replace password before any internet-facing deploy. -->
<clickhouse>
    <users>
        <default>
            <!-- Allow container bridge and host access during local development. -->
            <networks replace="replace">
                <ip>::/0</ip>
                <ip>0.0.0.0/0</ip>
            </networks>
            <password>secure_ch_pass</password>
        </default>
    </users>
</clickhouse>
