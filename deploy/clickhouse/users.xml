<!-- users.xml: default ClickHouse credentials for docker compose dev and staging. -->
<!-- Password must match CH_PASSWORD in .env. Restrict networks before any internet-facing deploy. -->
<clickhouse>
    <users>
        <default>
            <!-- Private RFC1918 and loopback only; processor and tracker reach CH via published host ports. -->
            <networks replace="replace">
                <ip>127.0.0.0/8</ip>
                <ip>10.0.0.0/8</ip>
                <ip>172.16.0.0/12</ip>
                <ip>192.168.0.0/16</ip>
            </networks>
            <password>secure_ch_pass</password>
        </default>
    </users>
</clickhouse>
