<!-- config.xml: ClickHouse server tuning for the ad-event analytics role. -->
<!-- Caps memory, disables heavy system logs, and listens on all interfaces for docker compose. -->
<clickhouse>
    <!-- Hard cap at 4 GiB so CH shares the host with tracker and Redis without OOM. -->
    <max_server_memory_usage>4294967296</max_server_memory_usage>
    <listen_host replace="replace">0.0.0.0</listen_host>
    <listen_try>1</listen_try>
    <listen_reuse_port>1</listen_reuse_port>
    <async_load_databases>false</async_load_databases>
    <!-- Drop system telemetry tables to reduce write amplification on small clusters. -->
    <query_log remove="remove" />
    <query_thread_log remove="remove" />
    <trace_log remove="remove" />
    <metric_log remove="remove" />
    <asynchronous_metric_log remove="remove" />
    <text_log remove="remove" />
    <skip_check_for_incorrect_settings>1</skip_check_for_incorrect_settings>
    <mlock_executable>false</mlock_executable>
</clickhouse>
