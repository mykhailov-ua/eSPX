# Staging cold-path env. Data plane endpoints are external (managed PG/Redis/CH), not compose host_ip.
apiVersion: v1
kind: ConfigMap
metadata:
  name: espx-env
  namespace: ${namespace}
  labels:
    app.kubernetes.io/part-of: espx
data:
  ENV: "${env}"
  REDIS_SHARD_COUNT: "4"
  REDIS_ADDRS: "${redis_addrs}"
  REDIS_STREAM_NAME: "ad:events:stream"
  FRAUD_STREAM_NAME: "ad:fraud:stream"
  REDIS_GROUP_NAME: "ad:processor:group"
  FILTER_TIMEOUT_MS: "${filter_timeout_ms}"
  MANAGEMENT_PORT: "8188"
  AUTH_SERVER_PORT: "51051"
  AUTH_METRICS_PORT: "9091"
  PAYMENT_SERVER_PORT: "51052"
  PAYMENT_WEBHOOK_PORT: "8187"
  BILLING_SERVER_PORT: "51054"
  NOTIFIER_PORT: "8085"
  NOTIFIER_METRICS_PORT: "8086"
  PROCESSOR_PORT: "8186"
  SETTLEMENT_SERVER_PORT: "51053"
  AUTH_SERVER_HOST: "auth"
  PAYMENT_SERVER_HOST: "payment"
  BILLING_SERVER_HOST: "billing"
  NOTIFIER_SERVER_HOST: "notifier"
  SETTLEMENT_SERVER_HOST: "management"
  MANAGEMENT_URL: "http://management:8188"
  EVENT_BATCH_SIZE: "1000"
  EVENT_FLUSH_MS: "500"
  CH_BATCH_SIZE: "50000"
  CH_FLUSH_INTERVAL_MS: "10000"
  MAX_WORKERS: "16"
  CH_MAX_WORKERS: "1"
  DB_PROCESSOR_MAX_CONNS: "16"
  DB_MIN_CONNS: "2"
  SHUTDOWN_TIMEOUT_MS: "15000"
  DRAIN_TIMEOUT_MS: "10000"
  WAIT_TIMEOUT_MS: "5000"
  STREAM_MAX_LEN: "100000"
  MAX_RETRIES: "5"
  STREAM_MIN_IDLE_MS: "300000"
  IVT_DETECTOR_ENABLED: "true"
  NOTIFIER_WORKER_CONCURRENCY: "2"
  NOTIFIER_GROUP_PARALLELISM: "2"
  NOTIFIER_DEDUP_COOLDOWN_SEC: "300"
  NOTIFIER_CLAIM_STALE_SEC: "300"
  NOTIFIER_RATE_LIMIT_PER_MINUTE: "60"
  OPS_ALERTS_ENABLED: "true"
  OPS_ALERT_COOLDOWN_SEC: "300"
  BLACKLIST_JANITOR_ENABLED: "true"
  BLACKLIST_JANITOR_INTERVAL_SEC: "60"
  ALERTMANAGER_WEBHOOK_ENABLED: "false"
  PAYMENT_FINANCIAL_RECON_INTERVAL_MS: "3600000"
  GEOIP_DB_PATH: "/deploy/geoip/GeoLite2-Country.mmdb"
  GEOIP_UPDATER_ENABLED: "false"
  GEOIP_UPDATE_INTERVAL_HOURS: "24"
  GEOIP_WATCHER_INTERVAL_SEC: "60"
  MAXMIND_EDITION_ID: "GeoLite2-Country"
  TRUSTED_PROXIES: "${trusted_proxies}"
  RTB_MODE: "off"
  RTB_BUDGET_AUTHORITY: "redis"
  # M1–M3 sharding control plane (staging rollout)
  MIGRATION_FENCE_ENABLED: "true"
  SLOT_MIGRATION_ENABLED: "true"
  QUOTA_MODE: "live"
  QUOTA_CHUNK_SIZE: "1000000"
  QUOTA_REFILL_THRESHOLD_PCT: "20"
  QUOTA_AUTO_REPAIR: "true"
  UDP_CONTROL_ENABLED: "true"
  UDP_FAIL_CLOSED: "true"
  UDP_MGMT_BIND_ADDR: ":8190"
  UDP_SYNC_INTERVAL_MS: "10000"
  UDP_DEFAULT_SHARD_RPS: "50000"
  UDP_TRACKER_ADDRS: "${udp_tracker_addrs}"
